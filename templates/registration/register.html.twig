{% extends 'base.html.twig' %}

{% block title %}Inscription
{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center bg-gray-100">

    <img src="{{ asset('Icon.png') }}" class="w-12 mb-4" />

    <h1 class="text-2xl font-bold mb-2">Créez votre compte</h1>

    <p class="text-gray-500 mb-6">
        Ou <a href="{{ path('app_login') }}" class="text-blue-600">connectez-vous à votre compte</a>
    </p>

    <div class="bg-white p-6 rounded-xl shadow w-full max-w-md">

        {{ form_start(registrationForm) }}

        <div class="grid grid-cols-2 gap-4">
            {{ form_row(registrationForm.first_name) }}
            {{ form_row(registrationForm.last_name) }}
        </div>

        {{ form_row(registrationForm.company_name) }}
        {{ form_row(registrationForm.siret) }}
        {{ form_row(registrationForm.iban) }}
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.plainPassword) }}
        {{ form_row(registrationForm.agreeTerms) }}

        <button class="w-full bg-blue-600 text-white py-2 rounded-lg mt-4">
            Créer mon compte
        </button>

        {{ form_end(registrationForm) }}
    </div>

</div>
{% endblock %}