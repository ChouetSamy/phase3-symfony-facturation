{% extends 'base.html.twig' %}

{% block title %}Connexion
{% endblock %}

{% block body %}
	<div class="min-h-screen flex items-center justify-center bg-gray-100">

		<div
			class="w-full max-w-md text-center">

			{# Icon #}
			<div class="flex justify-center mb-4">
				<img src="{{ asset('icon.png') }}" alt="icon" class="w-10 h-10">
			</div>

			{# Title #}
			<h1 class="text-2xl font-semibold text-gray-800 mb-2">
				Connectez-vous
			</h1>

			<p class="text-gray-500 mb-6">
				Ou
				<a href="{{ path('app_register') }}" class="text-blue-600 hover:underline">
					créez un compte gratuitement
				</a>
			</p>

			{# Card #}
			<div class="bg-white shadow-md rounded-xl p-6 text-left">

				<form
					method="post">

					{# Error message #}
					{% if error %}
						<div class="mb-4 text-red-600 text-sm">
							{{ error.messageKey|trans(error.messageData, 'security') }}
						</div>
					{% endif %}

					{# Email #}
					<div class="mb-4">
						<label class="block text-sm text-gray-600 mb-1">
							Adresse Email
						</label>
						<input type="email" name="_username" value="{{ last_username }}" placeholder="contact@entreprise.fr" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
					</div>

					{# Password #}
					<div class="mb-6">
						<label class="block text-sm text-gray-600 mb-1">
							Mot de passe
						</label>
						<input type="password" name="_password" placeholder="••••••••" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" required>
					</div>

					{# CSRF #}
					<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

					{#
					            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
					            See https://symfony.com/doc/current/security/remember_me.html
					
					            <div class="checkbox mb-3">
					                <input type="checkbox" name="_remember_me" id="_remember_me">
					                <label for="_remember_me">Remember me</label>
					            </div>
					        #}

					{# Submit #}
						<button type="submit" class="w-full bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700 transition"> Se connecter
					</button>

				</form>
			</div>
		</div>
	</div>
{% endblock %}
