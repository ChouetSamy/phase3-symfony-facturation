{% extends 'base.html.twig' %}
{% block title %}Factures
{% endblock %}

{% block body %}
	<div
		class="bg-gray-50 min-h-screen flex">

		{# Sidebar Component #}
		<twig:SideBarNav/>


		{# Content #}
		<main
			class="flex-1 ml-64 p-8">

			{# Header #}
			<div class="flex items-center justify-between mb-8">

				<h1 class="text-4xl font-bold text-gray-900">
					Factures
				</h1>

				<a href="{{ path('app_invoice_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-medium transition flex items-center gap-2">

					<span>+</span>
					Créer une facture
				</a>

			</div>


			{# Table container #}
			<div
				class="bg-white rounded-3xl border border-gray-200 overflow-hidden shadow-sm">

				{# Filters #}
				<div class="p-4 border-b border-gray-200 flex gap-3">

					<button class="px-5 py-2 rounded-xl bg-blue-100 text-blue-600 font-medium">
						Toutes
					</button>

					<button class="px-5 py-2 rounded-xl bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
						Brouillons
					</button>

					<button class="px-5 py-2 rounded-xl bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
						En attente
					</button>

					<button class="px-5 py-2 rounded-xl bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
						Payées
					</button>

				</div>


				{# Table #}
				<table class="w-full">

					<thead class="bg-white border-b border-gray-200 text-left">
						<tr>

							<th class="px-6 py-5 font-semibold text-gray-900">
								Numéro
							</th>

							<th class="px-6 py-5 font-semibold text-gray-900">
								Client
							</th>

							<th class="px-6 py-5 font-semibold text-gray-900">
								Statut
							</th>

							<th class="px-6 py-5 font-semibold text-gray-900">
								Total TTC
							</th>

							<th class="px-6 py-5 font-semibold text-gray-900">
								Actions
							</th>

							{% for invoice in invoices %}

								<tr class="border-b border-gray-100 hover:bg-gray-50 transition">

									<td class="px-6 py-5 font-medium text-gray-800">
										{{ invoice.number }}
									</td>

									<td class="px-6 py-5 text-gray-700">
										{{ invoice.client.name }}
									</td>

									<td class="px-6 py-5">

										{% if invoice.status.value == 'paid' %}

											<span class="px-4 py-1 rounded-full bg-green-100 text-green-700 text-sm font-medium">
												Payée
											</span>

										{% elseif invoice.status.value == 'pending_payment' %}

											<span class="px-4 py-1 rounded-full bg-orange-100 text-orange-700 text-sm font-medium">
												En attente
											</span>

										{% else %}

											<span class="px-4 py-1 rounded-full bg-gray-100 text-gray-700 text-sm font-medium">
												Brouillon
											</span>

										{% endif %}

									</td>

									<td class="px-6 py-5 font-semibold text-gray-900">
										{{ invoice.totalTtc }}
										€
									</td>

									<td class="px-6 py-5">

										<div class="flex items-center gap-4 text-blue-600">

											<a href="{{ path('app_invoice_show', {id: invoice.id}) }}" class="hover:text-blue-800 transition">
												👁️
											</a>

											<a href="{{ path('app_invoice_edit', {id: invoice.id}) }}" class="hover:text-blue-800 transition">
												✏️
											</a>

											<a href="#" class="hover:text-blue-800 transition">
												📧
											</a>

											<a href="#" class="hover:text-blue-800 transition">
												📄
											</a>

										</div>

									</td>

								</tr>

							{% else %}

								<tr>
									<td colspan="5" class="text-center py-12 text-gray-500">
										Aucune facture trouvée.
									</td>
								</tr>
							{% endfor %}
						</tr>
					</thead>
				</tbody>

			</table>

		</div>

	</main>

</div>{% endblock %}
