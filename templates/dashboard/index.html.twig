{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}

<div class="min-h-screen bg-gray-100 flex">


       <twig:SideBarNav />

        {# User block #}
        {% if app.user %}
        <div class="p-6 border-t border-gray-200">

            <div class="flex items-center gap-3 mb-6">
              
                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold">
                    {{ app.user.firstName|slice(0,1) }}{{ app.user.lastName|slice(0,1) }}
                </div>

                <div>
                    <p class="font-semibold text-gray-800">
                        {{ app.user.companyName }}
                    </p>

                    <p class="text-sm text-gray-500">
                        {{ app.user.email }}
                    </p>
                </div>
            </div>

            <a href="{{ path('app_logout') }}"
               class="text-red-500 hover:text-red-600 font-medium">
                Déconnexion
            </a>

        </div>
        {% endif %}
    </aside>

    {# =========================
       MAIN CONTENT
    ========================== #}
    <main class="flex-1 p-8">

        {# Header #}
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-800">
                Dashboard
            </h1>
        </div>

        {# =========================
           STATS
        ========================== #}
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

            {# Revenue #}
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">

                <div class="w-14 h-14 rounded-2xl bg-green-100 flex items-center justify-center text-3xl mb-4">
                    €
                </div>

                <p class="text-gray-500 mb-2">
                    Chiffre d'affaires
                </p>

                <h2 class="text-4xl font-bold text-gray-800">
                    {{ revenue|default(0) }} €
                </h2>

            </div>

            {# Pending invoices #}
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">

                <div class="w-14 h-14 rounded-2xl bg-orange-100 flex items-center justify-center text-3xl mb-4">
                    📄
                </div>

                <p class="text-gray-500 mb-2">
                    Factures en attente
                </p>

                <h2 class="text-4xl font-bold text-gray-800">
                    {{ pendingInvoices|default(0) }}
                </h2>

            </div>

            {# Clients #}
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">

                <div class="w-14 h-14 rounded-2xl bg-blue-100 flex items-center justify-center text-3xl mb-4">
                    👥
                </div>

                <p class="text-gray-500 mb-2">
                    Total Clients
                </p>

                <h2 class="text-4xl font-bold text-gray-800">
                    {{ clients|length }}
                </h2>

            </div>

            {# Products #}
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">

                <div class="w-14 h-14 rounded-2xl bg-purple-100 flex items-center justify-center text-3xl mb-4">
                    📦
                </div>

                <p class="text-gray-500 mb-2">
                    Total Produits
                </p>

                <h2 class="text-4xl font-bold text-gray-800">
                    {{ products|length }}
                </h2>

            </div>

        </div>

        {# =========================
           RECENT INVOICES
        ========================== #}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 mb-8">

            <div class="flex items-center justify-between mb-6">

                <h2 class="text-2xl font-semibold text-gray-800">
                    Dernières factures
                </h2>

                <a href="#"
                   class="text-blue-600 hover:underline">
                    Voir tout
                </a>

            </div>

            <div class="overflow-x-auto">

                <table class="w-full">

                    <thead>
                        <tr class="text-left text-gray-500 border-b border-gray-200">
                            <th class="pb-4">Numéro</th>
                            <th class="pb-4">Client</th>
                            <th class="pb-4">Statut</th>
                            <th class="pb-4">Montant</th>
                        </tr>
                    </thead>

                    <tbody>

                        {% for invoice in invoices %}

                            <tr class="border-b border-gray-100">

                                <td class="py-4 font-medium">
                                    {{ invoice.number }}
                                </td>

                                <td class="py-4">
                                    {{ invoice.client.name }}
                                </td>

                                <td class="py-4">

                                    {% if invoice.status.value == 'paid' %}
                                        <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm">
                                            Payée
                                        </span>

                                    {% elseif invoice.status.value == 'pending_payment' %}
                                        <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-sm">
                                            En attente
                                        </span>

                                    {% else %}
                                        <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm">
                                            Brouillon
                                        </span>
                                    {% endif %}

                                </td>

                                <td class="py-4 font-semibold">
                                    {{ invoice.totalTtc }} €
                                </td>

                            </tr>

                        {% endfor %}

                    </tbody>

                </table>

            </div>

        </div>

        {# =========================
           QUICK ACTIONS
        ========================== #}
        <div class="grid md:grid-cols-3 gap-6">

            <a href="#"
               class="bg-blue-50 border border-blue-100 rounded-2xl p-6 hover:bg-blue-100 transition">

                <h3 class="text-xl font-semibold text-blue-700 mb-2">
                    Créer une facture
                </h3>

                <p class="text-blue-600">
                    Nouvelle prestation
                </p>

            </a>

            <a href="#"
               class="bg-white border border-gray-200 rounded-2xl p-6 hover:bg-gray-50 transition">

                <h3 class="text-xl font-semibold text-gray-800 mb-2">
                    Ajouter un client
                </h3>

                <p class="text-gray-500">
                    Gérer votre répertoire
                </p>

            </a>

            <a href="#"
               class="bg-white border border-gray-200 rounded-2xl p-6 hover:bg-gray-50 transition">

                <h3 class="text-xl font-semibold text-gray-800 mb-2">
                    Créer un produit
                </h3>

                <p class="text-gray-500">
                    Ajouter une prestation
                </p>

            </a>

        </div>

    </main>

</div>

{% endblock %}